{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"],
      "collections/*": ["./.source/*"]
    },
    "types": ["vite/client", "@cloudflare/workers-types"]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    ".source/**/*.ts",
    ".react-router/types/**/*.d.ts",
    "source.config.ts",
    "vite.config.ts",
    "react-router.config.ts"
  ]
}
