{
  "name": "agent-hooks",
  "version": "1.0.134",
  "type": "module",
  "scripts": {
    "build": "yarn build:hooks && yarn build:dispatcher",
    "build:dispatcher": "node -e \"require('esbuild').buildSync({entryPoints:['src/dispatcher.ts'],bundle:true,platform:'node',format:'esm',loader:{'.md':'text'},outfile:'../../plugins/git-span/hooks/bin/dispatcher.mjs'})\"",
    "build:hooks": "claude-code-hooks -i \"src/**/*.ts\" -o \"../../plugins/git-span/hooks/hooks.json\"",
    "test": "vitest run",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@goodfoot/claude-code-hooks": "^1.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
