{
  "name": "agent-hooks",
  "version": "1.0.136",
  "type": "module",
  "scripts": {
    "build": "yarn build:claude && yarn build:codex",
    "build:claude": "yarn build:hooks",
    "build:codex": "yarn build:hooks:codex",
    "build:hooks": "yarn claude-code-hooks -i \"src/claude/**/*.ts\" -o \"../../plugins-claude/git-span/hooks/hooks.json\"",
    "build:hooks:codex": "yarn codex-hooks -i \"src/codex/**/*.ts\" -o \"../../plugins-codex/git-span/hooks/hooks.json\" --plugin-root",
    "claude-code-hooks": "node scripts/hooks-cli-wrapper.js @goodfoot/claude-code-hooks",
    "codex-hooks": "node scripts/hooks-cli-wrapper.js @goodfoot/codex-hooks",
    "test": "vitest run",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@goodfoot/claude-code-hooks": "^1.7.0",
    "@goodfoot/codex-hooks": "^1.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
