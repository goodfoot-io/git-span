{
  "name": "git-mesh",
  "displayName": "Git Mesh",
  "description": "Exposes the Git Mesh CLI in VS Code.",
  "version": "1.0.116",
  "publisher": "goodfoot",
  "type": "module",
  "engines": {
    "vscode": "^1.101.0",
    "node": ">=22"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/bundle.cjs",
  "contributes": {
    "commands": [
      {
        "command": "gitMesh.showVersion",
        "title": "Show CLI Version",
        "category": "Git Mesh"
      },
      {
        "command": "gitMesh.openTerminal",
        "title": "Open Terminal",
        "category": "Git Mesh"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node scripts/build/build-production.js",
    "build": "vsce package --no-dependencies --follow-symlinks && { [ -n \"${SKIP_INSTALL:-}\" ] || bash scripts/install-vsix.sh; }",
    "build:testing": "node scripts/build/build-testing.js",
    "test": "echo 'No tests to run: the extension package is not under active development at this time.'",
    "lint": "biome check --write --unsafe --max-diagnostics 500 ./src ./test ./scripts && jsdoczoom -l",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist out dist-test-* *.vsix tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.100.0",
    "@typescript/native-preview": "^7.0.0-dev",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "3.7.1",
    "esbuild": "^0.27.2",
    "glob": "^13.0.0",
    "jsdoczoom": "^1.2.3",
    "mocha": "^11.7.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/goodfoot-io/git-mesh"
  },
  "author": {
    "name": "Goodfoot Media LLC",
    "url": "https://goodfoot.io"
  }
}
