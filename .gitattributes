# Enforce LF line endings in the repository on all platforms
* text=auto
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
.span/** text eol=lf
.wiki/** text eol=lf

# Collapse the easy majority of .span/ conflicts in place during git merge.
.span/** merge=span

# Structurally merge .wiki/ span conflicts in place during git merge.
.wiki/** merge=wiki-span

# Resolve package version conflicts by picking the highest semver.
package.json merge=json-version
packages/extension/package.json merge=json-version
packages/git-span/package.json merge=json-version
