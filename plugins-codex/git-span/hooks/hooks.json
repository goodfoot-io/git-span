{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|shell|exec|local_shell",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/gate.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/post-tool-use.mjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
