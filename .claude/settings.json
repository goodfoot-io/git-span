{
  "env": {
    "MAX_MCP_OUTPUT_TOKENS": "100000",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "GIT_SPAN_ADVICE_DEBUG": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "100000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "250000"
  },
  "permissions": {
    "allow": [],
    "deny": [
      "EnterPlanMode",
      "ExitPlanMode",
      "DesignSync",
      "NotebookEdit",
      "PushNotification",
      "RemoteTrigger",
      "ReportFindings"
    ],
    "defaultMode": "bypassPermissions",
    "disableAutoMode": "disable"
  },
  "attribution": {
    "commit": "",
    "pr": "",
    "sessionUrl": false
  },
  "askUserQuestionTimeout": "never",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "{ printf '\\n--- %s ---\\n' \"$(date -Iseconds)\"; cat; printf '\\n'; } >> /workspace/.cards/logs/tool-response-probe.jsonl 2>&1"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "typescript-hooks@goodfoot": true,
    "typescript-claude-code-for-web-setup@goodfoot": false,
    "project@goodfoot": false,
    "vscode@goodfoot": true,
    "goodfoot@goodfoot": true,
    "jsdoczoom@goodfoot": true,
    "code-simplifier@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "claude-code-hooks@goodfoot": true,
    "git-span@git-span": true,
    "wiki@goodfoot-wiki": true
  },
  "extraKnownMarketplaces": {
    "git-span": {
      "source": {
        "source": "directory",
        "path": "/workspace"
      }
    },
    "goodfoot": {
      "source": {
        "source": "github",
        "repo": "goodfoot-io/marketplace"
      }
    },
    "goodfoot-wiki": {
      "source": {
        "source": "github",
        "repo": "goodfoot-io/wiki"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  }
}