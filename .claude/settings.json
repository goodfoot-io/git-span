{
  "env": {
    "MAX_MCP_OUTPUT_TOKENS": "100000",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "GIT_MESH_ADVICE_DEBUG": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "100000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_API_HOOKS_LOG_FILE": "/workspace/.cards/logs/claude-code-cards-api-hooks.log"
  },
  "permissions": {
    "allow": [],
    "deny": [
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "ExitWorktree",
      "LSP",
      "Read(.worktrees/)",
      "Read(./packages/extension/dist/)"
    ],
    "defaultMode": "bypassPermissions",
    "disableAutoMode": "disable"
  },
  "attribution": {
    "commit": "",
    "pr": "",
    "sessionUrl": false
  },
  "askUserQuestionTimeout": "never",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "{ printf '\\n--- %s ---\\n' \"$(date -Iseconds)\"; cat; printf '\\n'; } >> /workspace/.cards/logs/tool-response-probe.jsonl 2>&1"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": false,
    "typescript-hooks@goodfoot": true,
    "typescript-claude-code-for-web-setup@goodfoot": false,
    "project@goodfoot": false,
    "vscode@goodfoot": true,
    "goodfoot@goodfoot": true,
    "jsdoczoom@goodfoot": true,
    "expansion@goodfoot": true,
    "browser@goodfoot": true,
    "github@goodfoot": false,
    "code-simplifier@claude-plugins-official": true,
    "impeccable@impeccable": false,
    "frontend-design@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "claude-code-hooks@goodfoot": true,
    "last30days@last30days-skill": true,
    "git-mesh@git-mesh": true,
    "wiki@goodfoot-wiki": true,
    "cards@cards.management": true
  },
  "extraKnownMarketplaces": {
    "git-mesh": {
      "source": {
        "source": "directory",
        "path": "/workspace"
      }
    },
    "last30days-skill": {
      "source": {
        "source": "github",
        "repo": "mvanhorn/last30days-skill"
      }
    },
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    },
    "goodfoot": {
      "source": {
        "source": "github",
        "repo": "goodfoot-io/marketplace"
      }
    },
    "goodfoot-wiki": {
      "source": {
        "source": "github",
        "repo": "goodfoot-io/wiki"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "cards.management": {
      "source": {
        "source": "directory",
        "path": "/home/node/.vscode-server/data/User/globalStorage/goodfoot.cards/marketplace"
      }
    }
  }
}