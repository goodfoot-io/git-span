#!/bin/bash
# pre-commit dispatcher. Runs each sub-script in order. Fail closed: a
# non-zero sub-script aborts the commit. Edit PARTS to add/reorder concerns.
#
# Each sub-script is independently runnable and bash -n clean; run one by
# hand (e.g. .githooks/pre-commit.biome.sh) to debug it.
set -e
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
PARTS=(
    pre-commit.version-lock.sh
    pre-commit.wiki.sh
    pre-commit.biome.sh
)
for part in "${PARTS[@]}"; do
    script="$HOOK_DIR/$part"
    [ -x "$script" ] || continue
    "$script"
done
exit 0
