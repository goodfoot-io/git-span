#!/bin/bash
# post-commit dispatcher. Runs each sub-script in order. Advisory: this event
# fires after the commit has already landed, so a sub-script failure is
# reported but never aborts (you cannot un-commit from post-commit). Edit
# PARTS to add/reorder concerns.
#
# Each sub-script is independently runnable and bash -n clean.
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
PARTS=(
)
for part in "${PARTS[@]}"; do
    script="$HOOK_DIR/$part"
    [ -x "$script" ] || continue
    "$script" || echo "post-commit: $part failed (advisory, not blocking)" >&2
done
exit 0
