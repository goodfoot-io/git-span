#!/bin/bash
# post-commit dispatcher. Advisory: parts run for side effects only. A
# failing part is reported but never aborts the rest or the commit that
# already landed (you cannot un-commit from post-commit). Edit PARTS to
# add/reorder concerns.
#
# Each sub-script is independently runnable and bash -n clean; run one by
# hand (e.g. .githooks/post-commit.wiki-scaffold.sh) to debug it.
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
PARTS=(
    post-commit.wiki-scaffold.sh
)
for part in "${PARTS[@]}"; do
    script="$HOOK_DIR/$part"
    [ -x "$script" ] || continue
    "$script" || echo "post-commit: $part exited non-zero (ignored)"
done
exit 0
